#!/bin/sh
set -eu

if command -v brew >/dev/null 2>&1; then
  brew_cmd="$(command -v brew)"
elif [ -x /opt/homebrew/bin/brew ]; then
  brew_cmd="/opt/homebrew/bin/brew"
elif [ -x /usr/local/bin/brew ]; then
  brew_cmd="/usr/local/bin/brew"
else
  echo "Homebrew is not installed. Install Homebrew first:" >&2
  echo "  /bin/bash -c \"\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\"" >&2
  exit 1
fi

tmp_brewfile="$(mktemp)"
trap 'rm -f "$tmp_brewfile"' EXIT

cat >"$tmp_brewfile" <<'EOF_BREWFILE'
{{ include "Brewfile" }}
EOF_BREWFILE

if [ "{{ if dig "profile" "is_personal_pc" true . }}1{{ else }}0{{ end }}" = "1" ] && [ "${CHEZMOI_CI:-0}" != "1" ]; then
  cat >>"$tmp_brewfile" <<'EOF_PERSONAL_BREWFILE'
{{ include "Brewfile.personal" }}
EOF_PERSONAL_BREWFILE
fi

"$brew_cmd" bundle --file="$tmp_brewfile"
