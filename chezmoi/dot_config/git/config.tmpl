{{- $name := dig "git" "name" "" . -}}
{{- $email := dig "git" "email" "" . -}}
{{- if or (eq $name "") (eq $email "") -}}
{{- fail "gitのname/emailが未設定です。`chezmoi init` で質問に回答するか、~/.config/chezmoi/chezmoi.toml に [data.git] を設定してください。" -}}
{{- end -}}

[user]
	name = {{ $name | quote }}
	email = {{ $email | quote }}

[includeIf "gitdir:~/Developer/ghq/global/github.com/shsw228/"]
	path = ~/.config/git/config-shsw228

[ghq]
	root = ~/Developer/ghq/global

[include]
	path = ~/.config/git/config.local
