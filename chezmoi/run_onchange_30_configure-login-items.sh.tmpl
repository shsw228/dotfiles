#!/bin/sh
set -eu

osascript <<'APPLESCRIPT' >/dev/null 2>&1 || true
tell application "System Events"
  if not (exists login item "Raycast") then
    make new login item at end with properties {name:"Raycast", path:"/Applications/Raycast.app", hidden:false}
  end if

  if not (exists login item "AeroSpace") then
    make new login item at end with properties {name:"AeroSpace", path:"/Applications/AeroSpace.app", hidden:false}
  end if
end tell
APPLESCRIPT
